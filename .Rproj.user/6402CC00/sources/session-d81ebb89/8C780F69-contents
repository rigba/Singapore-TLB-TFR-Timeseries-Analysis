  arima_110 = ARIMA(TLB ~ pdq(1, 1, 0)),
  #arima_011 = ARIMA(TLB ~ pdq(0, 1, 1)), removed because auto
  arima_111 = ARIMA(TLB ~ pdq(1, 1, 1))
) 

tfr_fit <- tfr_train %>% model(
